<div class="fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-50" data-controller="flash-message">
  <%= message %>
</div>

<script>
  // 3초 후에 메시지 제거
  setTimeout(() => {
    const flashMessage = document.querySelector('[data-controller="flash-message"]');
    if (flashMessage) {
      flashMessage.remove();
    }
  }, 3000);
</script> 