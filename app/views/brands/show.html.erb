<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- 브레드크럼 -->
  <div class="mb-6">
    <nav class="flex" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-gray-700 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" do %>
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            홈
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
            <%= link_to "브랜드", brands_path, class: "ml-1 text-sm font-medium text-gray-700 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 md:ml-2" %>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 dark:text-gray-400 md:ml-2"><%= @brand.name %></span>
          </div>
        </li>
      </ol>
    </nav>
  </div>

  <!-- 브랜드 헤더 -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-8">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between">
      <div class="flex items-center space-x-4 mb-4 md:mb-0">
        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
          <span class="text-blue-600 dark:text-blue-400 font-bold text-2xl"><%= @brand.name.first %></span>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2"><%= @brand.name %></h1>
          <div class="flex items-center space-x-4">
            <span class="text-gray-600 dark:text-gray-400"><%= @brand.country %></span>
            <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full text-sm font-medium">
              <%= @brand.category == 'motorcycle' ? '오토바이' : '자전거' %>
            </span>
            <% if @brand.founded_year.present? %>
              <span class="text-gray-600 dark:text-gray-400">설립: <%= @brand.founded_year %></span>
            <% end %>
          </div>
        </div>
      </div>
      
      <div class="flex items-center space-x-3">
        <div class="text-center">
          <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= @brand.models.count %></p>
          <p class="text-sm text-gray-600 dark:text-gray-400">등록된 모델</p>
        </div>
      </div>
    </div>
  </div>

  <!-- 브랜드 설명 -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-8">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">브랜드 소개</h2>
    <p class="text-gray-700 dark:text-gray-300 leading-relaxed"><%= @brand.description %></p>
  </div>

  <!-- 모델 목록 -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 sm:mb-0"><%= @brand.name %> 모델</h2>
      
      <!-- 정렬 옵션 -->
      <div class="flex items-center space-x-4">
        <span class="text-sm text-gray-600 dark:text-gray-400">정렬:</span>
        <%= link_to "최신순", brand_path(@brand, sort: 'newest'), 
            class: "text-sm #{params[:sort] == 'newest' ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-600 dark:text-gray-400'} hover:text-blue-600 dark:hover:text-blue-400" %>
        <%= link_to "가격순", brand_path(@brand, sort: 'price'), 
            class: "text-sm #{params[:sort] == 'price' ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-600 dark:text-gray-400'} hover:text-blue-600 dark:hover:text-blue-400" %>
        <%= link_to "이름순", brand_path(@brand, sort: 'name'), 
            class: "text-sm #{params[:sort] == 'name' ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-600 dark:text-gray-400'} hover:text-blue-600 dark:hover:text-blue-400" %>
      </div>
    </div>

    <% if @models.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @models.each do |model| %>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow duration-300">
            <!-- 모델 헤더 -->
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm text-gray-600 dark:text-gray-400 font-medium"><%= model.year %></span>
              <span class="px-2 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded text-xs font-medium">
                <%= model.category == 'motorcycle' ? '오토바이' : '자전거' %>
              </span>
            </div>
            
            <!-- 모델명 -->
            <h3 class="font-semibold text-gray-900 dark:text-white mb-3 text-lg"><%= model.name %></h3>
            
            <!-- 가격 -->
            <div class="text-lg font-bold text-blue-600 dark:text-blue-400 mb-3">
              <%= model.price_formatted %>
            </div>
            
            <!-- 스펙 정보 -->
            <div class="space-y-2 mb-4">
              <% if model.engine_displacement.present? %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-600 dark:text-gray-400">배기량</span>
                  <span class="text-gray-900 dark:text-white"><%= model.engine_displacement %>cc</span>
                </div>
              <% end %>
              <% if model.weight.present? %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-600 dark:text-gray-400">무게</span>
                  <span class="text-gray-900 dark:text-white"><%= model.weight %>kg</span>
                </div>
              <% end %>
            </div>
            
            <!-- 액션 버튼 -->
            <div class="flex space-x-2">
              <%= link_to model_path(model), class: "flex-1 text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition-colors text-sm" do %>
                상세보기
              <% end %>
                             <%= link_to add_to_compare_path(model), method: :post, 
                   class: "flex-1 text-center bg-gray-100 dark:bg-gray-600 text-gray-700 dark:text-gray-300 py-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-500 transition-colors text-sm" do %>
                 비교
               <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- 페이지네이션 -->
      <% if @models.respond_to?(:total_pages) && @models.total_pages > 1 %>
        <div class="mt-8 flex justify-center">
          <%= paginate @models, theme: 'tailwind' %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12">
        <div class="text-gray-400 dark:text-gray-500 mb-4">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0112 15c-2.34 0-4.47-.881-6.08-2.33"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">등록된 모델이 없습니다</h3>
        <p class="text-gray-600 dark:text-gray-300">이 브랜드의 모델이 아직 등록되지 않았습니다.</p>
      </div>
    <% end %>
  </div>


</div>
