<!-- 브랜드 헤더 -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @brand.name %></h1>
      <p class="text-gray-600 dark:text-gray-300 mt-2"><%= @brand.description %></p>
    </div>
    <span class="px-4 py-2 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full text-sm font-medium">
      <%= @brand.category == 'motorcycle' ? '오토바이' : '자전거' %>
    </span>
  </div>
  
  <!-- 브랜드 정보 카드 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">기본 정보</h3>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-400">국가</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @brand.country %></span>
        </div>
        <% if @brand.founded_year %>
          <div class="flex justify-between">
            <span class="text-gray-600 dark:text-gray-400">설립연도</span>
            <span class="font-medium text-gray-900 dark:text-white"><%= @brand.founded_year %></span>
          </div>
        <% end %>
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-400">모델 수</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @brand.models.count %>개</span>
        </div>
      </div>
    </div>
    
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">카테고리별 모델</h3>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-400">오토바이</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @brand.models.motorcycles.count %>개</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-400">자전거</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @brand.models.bicycles.count %>개</span>
        </div>
      </div>
    </div>
    
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">연도별 분포</h3>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-400">최신 모델</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @brand.models.maximum(:year) || 'N/A' %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600 dark:text-gray-400">최초 모델</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @brand.models.minimum(:year) || 'N/A' %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 모델 목록 -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @brand.name %> 모델</h2>
    <a href="<%= models_path(brand_id: @brand.id) %>" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
      전체 모델 보기 →
    </a>
  </div>
  
  <% if @models.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @models.each do |model| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300">
          <div class="p-6">
            <!-- 모델 헤더 -->
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= model.name %></h3>
              <span class="px-2 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded text-xs">
                <%= model.year %>
              </span>
            </div>
            
            <!-- 모델 정보 -->
            <div class="space-y-2 mb-4">
              <% if model.price %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-600 dark:text-gray-400">가격</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= model.price_formatted %></span>
                </div>
              <% end %>
              
              <% if model.engine_displacement %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-600 dark:text-gray-400">배기량</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= model.engine_displacement %>cc</span>
                </div>
              <% end %>
              
              <% if model.weight %>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-600 dark:text-gray-400">무게</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= model.weight %>kg</span>
                </div>
              <% end %>
            </div>
            
            <!-- 액션 버튼 -->
            <a href="<%= model_path(model) %>" class="block w-full bg-blue-600 hover:bg-blue-700 text-white text-center px-4 py-2 rounded-lg text-sm font-medium transition-colors">
              상세 정보
            </a>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg shadow-md">
      <div class="text-gray-400 dark:text-gray-500 mb-4">
        <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0112 15c-2.34 0-4.47-.881-6.08-2.33"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">등록된 모델이 없습니다</h3>
      <p class="text-gray-600 dark:text-gray-300">이 브랜드의 모델이 곧 추가될 예정입니다.</p>
    </div>
  <% end %>
</div>

<!-- 관련 브랜드 (같은 카테고리) -->
<div class="mb-8">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">관련 브랜드</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% Brand.where(category: @brand.category).where.not(id: @brand.id).limit(3).each do |related_brand| %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300">
        <div class="p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2"><%= related_brand.name %></h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm mb-4 line-clamp-2"><%= related_brand.description %></p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400"><%= related_brand.country %></span>
            <span class="text-sm text-gray-500 dark:text-gray-400"><%= related_brand.models.count %>개 모델</span>
          </div>
          <a href="<%= brand_path(related_brand) %>" class="block mt-4 text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
            자세히 보기 →
          </a>
        </div>
      </div>
    <% end %>
  </div>
</div>
