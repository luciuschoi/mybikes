<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- 검색 및 필터링 섹션 -->
  <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg p-6 mb-8">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">브랜드 검색</h2>
    
    <%= form_with url: brands_path, method: :get, local: true, class: "space-y-6" do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- 검색어 입력 -->
        <div class="md:col-span-2">
          <%= form.label :search, "검색어", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.text_field :search, 
              value: params[:search], 
              placeholder: "브랜드명, 국가로 검색...",
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white" %>
        </div>
        
        <!-- 카테고리 필터 -->
        <div>
          <%= form.label :category, "카테고리", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.select :category, 
              options_for_select([
                ['전체', ''],
                ['오토바이', 'motorcycle'],
                ['자전거', 'bicycle']
              ], params[:category]),
              {},
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white" %>
        </div>
      </div>
      
      <!-- 추가 필터 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- 국가 필터 -->
        <div>
          <%= form.label :country, "국가", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.select :country, 
              options_for_select([
                ['전체', ''],
                ['일본', 'Japan'],
                ['독일', 'Germany'],
                ['이탈리아', 'Italy'],
                ['미국', 'USA'],
                ['영국', 'UK'],
                ['프랑스', 'France'],
                ['스페인', 'Spain'],
                ['대만', 'Taiwan'],
                ['중국', 'China'],
                ['한국', 'Korea']
              ], params[:country]),
              {},
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white" %>
        </div>
        
        <!-- 설립 연도 범위 -->
        <div>
          <%= form.label :founded_from, "설립 연도 (시작)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.number_field :founded_from, 
              value: params[:founded_from], 
              min: 1800, 
              max: Date.current.year,
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white" %>
        </div>
        
        <div>
          <%= form.label :founded_to, "설립 연도 (끝)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.number_field :founded_to, 
              value: params[:founded_to], 
              min: 1800, 
              max: Date.current.year,
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white" %>
        </div>
      </div>
      
      <!-- 버튼 그룹 -->
      <div class="flex flex-col sm:flex-row gap-3">
        <%= form.submit "검색", class: "px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors" %>
        <%= link_to "초기화", brands_path, class: "px-6 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors text-center" %>
      </div>
    <% end %>
  </div>

  <!-- 검색 결과 헤더 -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">브랜드 목록</h1>
      <% if params[:search].present? || params[:category].present? || params[:country].present? %>
        <p class="text-gray-600 dark:text-gray-400 mt-2">
          검색 결과: <%= @brands.total_count %>개 브랜드
        </p>
      <% end %>
    </div>
    
    <!-- 정렬 옵션 -->
    <div class="flex items-center space-x-4 mt-4 sm:mt-0">
      <span class="text-sm text-gray-600 dark:text-gray-400">정렬:</span>
      <%= link_to "이름순", brands_path(sort: 'name'), 
          class: "text-sm #{params[:sort] == 'name' ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-600 dark:text-gray-400'} hover:text-blue-600 dark:hover:text-blue-400" %>
      <%= link_to "설립연도순", brands_path(sort: 'founded'), 
          class: "text-sm #{params[:sort] == 'founded' ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-600 dark:text-gray-400'} hover:text-blue-600 dark:hover:text-blue-400" %>
      <%= link_to "최신순", brands_path(sort: 'newest'), 
          class: "text-sm #{params[:sort] == 'newest' ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-gray-600 dark:text-gray-400'} hover:text-blue-600 dark:hover:text-blue-400" %>
    </div>
  </div>

  <!-- 브랜드 그리드 -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @brands.each do |brand| %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300">
        <div class="p-6">
          <!-- 브랜드명 -->
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3"><%= brand.name %></h3>
          
          <!-- 설명 -->
          <p class="text-gray-700 dark:text-gray-300 text-sm mb-4 leading-relaxed">
            <%= brand.description %>
          </p>
          
          <!-- 브랜드 정보 -->
          <div class="space-y-2 mb-4">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600 dark:text-gray-400">국가:</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= brand.country %></span>
            </div>
            
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600 dark:text-gray-400">설립연도:</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= brand.founded_year %></span>
            </div>
            
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600 dark:text-gray-400">카테고리:</span>
              <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded text-xs font-medium">
                <%= brand.category == 'motorcycle' ? '오토바이' : '자전거' %>
              </span>
            </div>
          </div>
          
          <!-- 모델 수 -->
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm text-gray-600 dark:text-gray-400">등록된 모델:</span>
            <span class="text-sm font-bold text-green-600 dark:text-green-400"><%= brand.models.count %>개</span>
          </div>
          
          <!-- 상세 정보 링크 -->
          <a href="<%= brand_path(brand) %>" 
             class="block w-full text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition-colors">
            브랜드 상세보기
          </a>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 페이지네이션 -->
  <% if @brands.respond_to?(:total_pages) && @brands.total_pages > 1 %>
    <div class="mt-8 flex justify-center">
      <%= paginate @brands, theme: 'tailwind' %>
    </div>
  <% end %>
</div>
