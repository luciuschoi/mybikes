<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- 브레드크럼 -->
  <div class="mb-6">
    <nav class="flex" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-gray-700 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" do %>
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            홈
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
            <%= link_to "모델", models_path, class: "ml-1 text-sm font-medium text-gray-700 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 md:ml-2" %>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 dark:text-gray-400 md:ml-2"><%= @model.name %></span>
          </div>
        </li>
      </ol>
    </nav>
  </div>

  <!-- 모델 상세 정보 -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- 메인 정보 -->
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6">
        <!-- 헤더 -->
        <div class="flex items-start justify-between mb-6">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2"><%= @model.name %></h1>
            <p class="text-lg text-gray-600 dark:text-gray-400"><%= @model.brand.name %></p>
          </div>
          <div class="flex items-center space-x-2">
            <span class="px-3 py-1 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded-full text-sm font-medium">
              <%= @model.category == 'motorcycle' ? '오토바이' : '자전거' %>
            </span>
            <%= link_to add_to_compare_path(@model), method: :post, 
                class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm" do %>
              비교에 추가
            <% end %>
          </div>
        </div>

        <!-- 가격 정보 -->
        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mb-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-600 dark:text-gray-400">가격</p>
              <p class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= @model.price_formatted %></p>
            </div>
            <div class="text-right">
              <p class="text-sm text-gray-600 dark:text-gray-400">연도</p>
              <p class="text-lg font-semibold text-gray-900 dark:text-white"><%= @model.year %></p>
            </div>
          </div>
        </div>

        <!-- 스펙 정보 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">기본 스펙</h3>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">카테고리</span>
                <span class="font-medium text-gray-900 dark:text-white">
                  <%= @model.category == 'motorcycle' ? '오토바이' : '자전거' %>
                </span>
              </div>
              <% if @model.engine_displacement.present? %>
                <div class="flex justify-between">
                  <span class="text-gray-600 dark:text-gray-400">배기량</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= @model.engine_displacement %>cc</span>
                </div>
              <% end %>
              <% if @model.weight.present? %>
                <div class="flex justify-between">
                  <span class="text-gray-600 dark:text-gray-400">무게</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= @model.weight %>kg</span>
                </div>
              <% end %>
              <% if @model.fuel_type.present? %>
                <div class="flex justify-between">
                  <span class="text-gray-600 dark:text-gray-400">연료</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= @model.fuel_type %></span>
                </div>
              <% end %>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">브랜드 정보</h3>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">브랜드</span>
                <span class="font-medium text-gray-900 dark:text-white"><%= @model.brand.name %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">국가</span>
                <span class="font-medium text-gray-900 dark:text-white"><%= @model.brand.country %></span>
              </div>
              <% if @model.brand.founded_year.present? %>
                <div class="flex justify-between">
                  <span class="text-gray-600 dark:text-gray-400">설립연도</span>
                  <span class="font-medium text-gray-900 dark:text-white"><%= @model.brand.founded_year %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- 브랜드 설명 -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">브랜드 소개</h3>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed"><%= @model.brand.description %></p>
      </div>
    </div>

    <!-- 사이드바 -->
    <div class="lg:col-span-1">
      <!-- 브랜드 카드 -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">브랜드 정보</h3>
        <div class="space-y-3">
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
              <span class="text-blue-600 dark:text-blue-400 font-bold text-lg"><%= @model.brand.name.first %></span>
            </div>
            <div>
              <p class="font-medium text-gray-900 dark:text-white"><%= @model.brand.name %></p>
              <p class="text-sm text-gray-600 dark:text-gray-400"><%= @model.brand.country %></p>
            </div>
          </div>
          <div class="pt-3 border-t border-gray-200 dark:border-gray-700">
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">등록된 모델</p>
            <p class="text-lg font-bold text-green-600 dark:text-green-400"><%= @model.brand.models.count %>개</p>
          </div>
          <%= link_to brand_path(@model.brand), class: "block w-full text-center bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition-colors mt-4" do %>
            브랜드 상세보기
          <% end %>
        </div>
      </div>

      <!-- 관련 모델 -->
      <% if @related_models.any? %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">관련 모델</h3>
          <div class="space-y-3">
            <% @related_models.each do |model| %>
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-3">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white"><%= model.name %></p>
                    <p class="text-sm text-gray-600 dark:text-gray-400"><%= model.year %></p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-blue-600 dark:text-blue-400"><%= model.price_formatted %></p>
                    <%= link_to "보기", model_path(model), class: "text-xs text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>


</div>
